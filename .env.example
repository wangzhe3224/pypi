# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google
GOOGLE_API_KEY=

# Zhipu AI / Z.AI
# Get your key from: https://open.bigmodel.cn (China) or https://z.ai/model-api (International)
ZHIPUAI_API_KEY=
# Alternative env var name (either works)
# ZAI_API_KEY=

# Zhipu region: china, international, or coding (for GLM Coding Plan)
ZHIPUAI_REGION=china

# Custom base URL (optional, overrides default based on region)
# ZHIPUAI_BASE_URL=

# Debug mode
PI_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
PI_LOG_LEVEL=INFO
